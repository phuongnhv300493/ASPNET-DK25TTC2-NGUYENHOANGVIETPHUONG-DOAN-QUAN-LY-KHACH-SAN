@model IEnumerable<datphongkhachsan.Data.DataModel.ChuongTrinh>

@{
    ViewData["Title"] = "Danh sách";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Danh sách chương trình</h1>

<p>
    <a class="btn btn-outline-primary" asp-action="Create">Tạo mới</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.TenChuongTrinh)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.TiLeThayDoiGia)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.IsTang)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.TenChuongTrinh)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.TiLeThayDoiGia)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.IsTang)
            </td>
            <td>
                <a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@item.Id">Sửa</a> |
                <a class="btn btn-outline-info" asp-action="Details" asp-route-id="@item.Id">Chi tiết</a> |
                <a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id">Xóa</a>
            </td>
        </tr>
}
    </tbody>
</table>
