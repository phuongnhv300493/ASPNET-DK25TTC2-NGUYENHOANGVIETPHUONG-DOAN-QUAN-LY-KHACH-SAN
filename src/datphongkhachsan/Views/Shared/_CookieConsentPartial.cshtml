@using Microsoft.AspNetCore.Http.Features

@{
    var consentFeature = Context.Features.Get<ITrackingConsentFeature>();
    var showBanner = !consentFeature?.CanTrack ?? false;
    var cookieString = consentFeature?.CreateConsentCookie();
}

@if (showBanner)
{
    <div id="cookieConsent" class="alert alert-info alert-dismissible fade show" role="alert">
        Sử dụng khoảng này để tóm tắt chính sách bảo mật và cookie của bạn. <a asp-page="/Privacy">Tìm Hiểu Thêm</a>.
        <button type="button" class="accept-policy close" data-dismiss="alert" aria-label="Đóng" data-cookie-string="@cookieString">
            <span aria-hidden="true">Chấp Nhận</span>
        </button>
    </div>
    <script>
        (function () {
            var button = document.querySelector("#cookieConsent button[data-cookie-string]");
            button.addEventListener("click", function (event) {
                document.cookie = button.dataset.cookieString;
            }, false);
        })();
    </script>
}