@model datphongkhachsan.Data.DataModel.ViewModel.PhongViewModel

@{
    ViewData["Title"] = "Xóa";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h1>Xóa</h1>

<h3>Bạn có chắc chắn muốn xóa mục này?</h3>
<div>
    <h4>Phòng</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.phongs.Name)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.phongs.Name)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.phongs.ShortDescription)
        </dt>
        <dd class = "col-sm-10">5
            @Html.DisplayFor(model => model.phongs.ShortDescription)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.phongs.Price)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.phongs.Price)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.phongs.ChuongTrinh)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.phongs.ChuongTrinh.TenChuongTrinh)
        </dd class>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.phongs.LoaiPhong)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.phongs.LoaiPhong.Name)
        </dd class>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="phongs.Id" />
        <input type="submit" value="Xóa" class="btn btn-danger" /> |
        <a asp-action="Index">Quay lại danh sách</a>
    </form>
</div>
